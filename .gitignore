# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large binary files (Excel templates, PDFs)
*.xlsx
*.pdf
*.html
_pdf_text.txt
Links utiles.txt

# dist output
/dist

# installer build artifacts (large binaries)
/installer/staging
/installer/downloads
/installer/output
/installer/icon/techops.ico
/installer/license.txt
